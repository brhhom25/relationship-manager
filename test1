const toMin=t=>{if(!t)return 0;const[h,m]=t.split(':').map(Number);return h*60+m;};
const toTime=m=>{const h=Math.floor((m%1440)/60),mn=m%60;return`${String(h).padStart(2,'0')}:${String(mn).padStart(2,'0')}`;};
const todayISO=()=>new Date().toISOString().split('T')[0];
const getViewDateObj=()=>{const d=new Date();d.setDate(d.getDate()+currentDayOffset);return d;};
const getViewDateISO=()=>getViewDateObj().toISOString().split('T')[0];
const dateToISO=d=>d.toISOString().split('T')[0];
const isEvent=a=>a&&a.category==='Events and Special Days';
function getViewActs(day,dateStr){return(activities[day]||[]).filter(a=>!a.specificDate||a.specificDate===dateStr);}
function getDayActs(){return getViewActs(currentDay,getViewDateISO());}
function sortDay(day){(activities[day]||[]).sort((a,b)=>toMin(a.time)-toMin(b.time));}

