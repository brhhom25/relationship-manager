:root{--primary-color:#FF6B6B;--secondary-color:#4ECDC4;--accent-color:#FFE66D;--background-color:#F7FFF7;--text-color:#292F36;--glass-bg:rgba(255,255,255,0.95);--glass-border:rgba(255,255,255,0.4);--shadow:0 4px 12px rgba(0,0,0,0.15);--free-time-color:#6B5B95;--selected-bg:#E0F7FF;--input-bg:#FFFFFF;--input-border:#FF6B6B;--button-hover:#4ECDC4;--focus-border:#FFE66D;--tab-active:#FF6B6B;--tab-inactive:#A5A5A5;--success-color:#2ECC71;--warning-color:#FF9F43;--error-color:#FF6B6B;--focus-shadow:0 0 0 3px rgba(255,230,109,0.5);--on-time-color:#2ECC71;--late-color:#FF9F43;--missed-color:#FF6B6B;--duplicate-color:#9B59B6;--events-color:#e84393;--ai-color:#6366f1;--ai-gradient:linear-gradient(135deg,#6366f1,#8b5cf6);--wa-color:#25D366;}
[data-theme="ocean"]{--primary-color:#0077BE;--secondary-color:#00A8E8;--accent-color:#00D9FF;--tab-active:#0077BE;}
[data-theme="sunset"]{--primary-color:#FF6B35;--secondary-color:#F7931E;--accent-color:#FDC830;--tab-active:#FF6B35;}
[data-theme="forest"]{--primary-color:#2D6A4F;--secondary-color:#52B788;--accent-color:#95D5B2;--tab-active:#2D6A4F;}
[data-theme="purple"]{--primary-color:#7209B7;--secondary-color:#B185DB;--accent-color:#D8BBE7;--tab-active:#7209B7;}
[data-theme="minimal"]{--primary-color:#495057;--secondary-color:#6C757D;--accent-color:#ADB5BD;--tab-active:#495057;}
*{box-sizing:border-box;}
body{font-family:'Poppins',sans-serif;background:var(--background-color);color:var(--text-color);margin:0;padding:0;line-height:1.6;background-image:radial-gradient(circle at 10% 20%,rgba(255,230,109,0.1) 0%,rgba(78,205,196,0.1) 90%);touch-action:pan-x pan-y;}
.container{max-width:1200px;margin:0 auto;padding:20px;}
h2,h3{color:var(--primary-color);margin-bottom:20px;}
input,select,textarea{width:100%;padding:12px;border-radius:10px;border:2px solid var(--input-border);background:var(--input-bg);font-family:'Poppins',sans-serif;font-size:1rem;margin-bottom:12px;transition:all .3s ease;box-shadow:var(--shadow);box-sizing:border-box;}
select{min-height:44px;}
input:focus,select:focus,textarea:focus{background:var(--selected-bg);border-color:var(--focus-border);outline:none;box-shadow:var(--focus-shadow);}
.tab-nav{display:flex;margin-bottom:20px;border-bottom:2px solid var(--glass-border);background:var(--glass-bg);border-radius:12px;padding:8px;box-shadow:var(--shadow);overflow-x:auto;-webkit-overflow-scrolling:touch;min-height:70px;align-items:center;gap:4px;}
.tab-btn{padding:12px 18px;background:none;border:none;cursor:pointer;font-size:1rem;font-weight:600;color:var(--tab-inactive);position:relative;transition:all .3s ease;border-radius:10px;display:flex;flex-direction:column;align-items:center;min-width:76px;flex-shrink:0;min-height:58px;justify-content:center;touch-action:manipulation;}
.tab-btn span.icon{font-size:1.6rem;margin-bottom:4px;}
.tab-btn .tab-label{font-size:0.8rem;display:none;}
.tab-btn:hover{background:rgba(255,107,107,0.12);transform:translateY(-2px);}
.tab-btn.active{color:var(--tab-active);background:rgba(255,107,107,0.2);box-shadow:0 4px 8px rgba(255,107,107,0.2);}
.tab-btn.active::after{content:'';position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);width:80%;height:4px;background:var(--tab-active);border-radius:2px;}
.tab-btn.ai-tab-btn.active{color:var(--ai-color);background:rgba(99,102,241,0.15);}
.tab-btn.ai-tab-btn.active::after{background:var(--ai-color);}
.tab-content{display:none;animation:fadeIn .4s ease;}
.tab-content.active{display:block;}
.subnav{display:flex;margin-bottom:18px;background:var(--glass-bg);border-radius:12px;padding:6px;box-shadow:var(--shadow);overflow-x:auto;min-height:54px;align-items:center;gap:4px;}
.subbtn{padding:10px 18px;background:none;border:none;cursor:pointer;font-size:.95rem;font-weight:600;color:var(--tab-inactive);position:relative;transition:all .3s ease;border-radius:10px;flex-shrink:0;min-height:44px;white-space:nowrap;}
.subbtn:hover{background:rgba(255,107,107,0.1);}
.subbtn.active{color:var(--tab-active);background:rgba(255,107,107,0.2);}
.subbtn.active::after{content:'';position:absolute;bottom:-6px;left:50%;transform:translateX(-50%);width:80%;height:3px;background:var(--tab-active);border-radius:2px;}
.subcontent{display:none;animation:fadeIn .4s ease;}
.subcontent.active{display:block;}
.glass-card{background:var(--glass-bg);border-radius:14px;padding:22px;margin-bottom:22px;box-shadow:var(--shadow);border:1px solid var(--glass-border);}
.section-title{color:var(--primary-color);margin:0 0 16px;font-size:1.2rem;display:flex;align-items:center;gap:10px;}
.btn{padding:12px 22px;border:none;border-radius:10px;cursor:pointer;font-family:'Poppins',sans-serif;font-size:.95rem;font-weight:600;transition:all .3s ease;display:inline-flex;align-items:center;gap:8px;min-height:46px;touch-action:manipulation;}
.btn:hover{transform:translateY(-2px);filter:brightness(1.06);}
.btn-primary{background:var(--primary-color);color:#fff;box-shadow:0 4px 10px rgba(255,107,107,.3);}
.btn-secondary{background:var(--secondary-color);color:#fff;box-shadow:0 4px 10px rgba(78,205,196,.3);}
.btn-success{background:var(--success-color);color:#fff;}
.btn-warning{background:var(--warning-color);color:#fff;}
.btn-danger{background:var(--error-color);color:#fff;}
.btn-ai{background:var(--ai-gradient);color:#fff;box-shadow:0 4px 12px rgba(99,102,241,.35);}
.btn-wa{background:var(--wa-color);color:#fff;box-shadow:0 4px 10px rgba(37,211,102,.3);}
.btn-sm{padding:7px 14px;font-size:.82rem;min-height:34px;}
.date-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:14px;}
.date-field-group{display:flex;flex-direction:column;gap:4px;}
.date-field-label{font-weight:700;font-size:.8rem;color:var(--primary-color);}
.date-field-input{padding:11px 13px;border:2px solid var(--input-border);background:var(--input-bg);border-radius:10px;font-family:'Poppins',sans-serif;font-size:.95rem;font-weight:600;color:var(--text-color);min-height:44px;width:100%;margin:0;}
.cal-nav-bar{display:flex;align-items:center;gap:10px;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;padding:10px 16px;margin-bottom:14px;box-shadow:var(--shadow);flex-wrap:wrap;}
.cal-nav-btn{width:38px;height:38px;background:var(--primary-color);color:#fff;border:none;border-radius:50%;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.cal-nav-btn:hover{background:var(--button-hover);transform:scale(1.1);}
.cal-nav-label{flex:1;text-align:center;font-weight:700;font-size:.95rem;color:var(--primary-color);min-width:160px;}
.cal-nav-today{padding:7px 14px;background:var(--secondary-color);color:#fff;border:none;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;transition:all .2s;}
.calendar-view{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:14px;padding:20px;box-shadow:var(--shadow);position:relative;overflow:hidden;}
.calendar-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;}
.calendar-hour{padding:12px;text-align:center;border-radius:10px;background:rgba(255,107,107,.1);border:1px solid var(--glass-border);font-weight:600;color:var(--primary-color);display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:80px;}
.calendar-slot{min-height:80px;cursor:pointer;transition:all .3s;padding:10px;border-radius:10px;background:var(--glass-bg);border:1px solid var(--glass-border);}
.calendar-slot.empty{background:rgba(255,255,255,.5);border:2px dashed var(--secondary-color);}
.calendar-slot.drag-over{background:rgba(78,205,196,.25);border:2px solid var(--secondary-color);}
.calendar-activity{background:var(--primary-color);color:#fff;padding:9px;border-radius:8px;margin:3px;cursor:grab;transition:transform .3s;font-size:.92rem;font-weight:500;min-height:46px;display:flex;flex-direction:column;justify-content:center;position:relative;user-select:none;}
.calendar-activity:hover{transform:scale(1.04);}
.calendar-activity.activity-done{background:#4a4a4a!important;opacity:.82;}
.calendar-activity.activity-done .act-name-text{text-decoration:line-through;opacity:.75;}
.act-time-disp{font-size:.82rem;margin-top:3px;opacity:.9;}
.drag-ghost{position:fixed;pointer-events:none;z-index:9999;padding:8px 14px;background:var(--primary-color);color:#fff;border-radius:8px;font-size:.88rem;font-weight:600;box-shadow:0 8px 20px rgba(0,0,0,.3);opacity:.9;}
.view-agenda{display:flex;flex-direction:column;gap:0;background:var(--glass-bg);border-radius:12px;overflow:hidden;border:1px solid var(--glass-border);}
.agenda-block{display:flex;align-items:stretch;min-height:50px;border-bottom:1px solid var(--glass-border);}
.agenda-block:last-child{border-bottom:none;}
.agenda-hour-lbl{width:72px;flex-shrink:0;padding:9px 10px;font-weight:700;font-size:.84rem;color:var(--primary-color);background:rgba(255,107,107,.07);display:flex;align-items:center;border-right:2px solid var(--glass-border);}
.agenda-area{flex:1;padding:5px 12px;display:flex;flex-direction:column;gap:5px;justify-content:center;min-height:50px;}
.agenda-chip{border-radius:9px;padding:8px 12px;font-size:.9rem;font-weight:500;cursor:grab;transition:all .2s;display:flex;align-items:center;justify-content:space-between;gap:8px;color:#fff;user-select:none;}
.view-timeline{display:block;overflow-x:auto;background:var(--glass-bg);border-radius:12px;padding:14px;border:1px solid var(--glass-border);}
.tl-wrapper{position:relative;min-width:480px;}
.tl-ruler{display:flex;border-bottom:2px solid var(--primary-color);background:rgba(255,107,107,.07);border-radius:8px 8px 0 0;}
.tl-ruler-hour{flex:1;text-align:center;padding:5px 2px;font-size:.7rem;font-weight:700;color:var(--primary-color);border-right:1px solid var(--glass-border);min-width:34px;}
.tl-track{position:relative;height:60px;margin:8px 0 3px;background:rgba(255,255,255,.5);border-radius:10px;border:1px solid var(--glass-border);}
.tl-block{position:absolute;border-radius:8px;color:#fff;font-size:.74rem;font-weight:600;padding:4px 7px;cursor:grab;overflow:hidden;box-sizing:border-box;transition:filter .2s;display:flex;flex-direction:column;justify-content:center;min-width:26px;user-select:none;}
.tl-now-line{position:absolute;top:-5px;bottom:-5px;width:2px;background:var(--error-color);z-index:10;pointer-events:none;}
.view-kanban{display:flex;gap:14px;overflow-x:auto;padding-bottom:8px;}
.kanban-col{flex:0 0 220px;background:rgba(255,255,255,.6);border:1px solid var(--glass-border);border-radius:14px;padding:12px;display:flex;flex-direction:column;gap:9px;min-height:380px;}
.kanban-col.drag-over{background:rgba(78,205,196,.12);border:2px dashed var(--secondary-color);}
.kanban-col-hdr{font-weight:700;font-size:.9rem;color:var(--primary-color);text-align:center;padding-bottom:9px;border-bottom:2px solid var(--glass-border);display:flex;align-items:center;justify-content:center;gap:7px;}
.kanban-card{border-radius:10px;padding:11px;color:#fff;cursor:grab;box-shadow:0 2px 7px rgba(0,0,0,.14);transition:transform .2s;min-height:66px;display:flex;flex-direction:column;gap:3px;user-select:none;}
.kanban-card:hover{transform:translateY(-3px);}
.view-focus{display:flex;flex-direction:column;gap:10px;}
.focus-row{display:flex;align-items:center;gap:12px;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:14px;padding:12px 16px;box-shadow:var(--shadow);transition:transform .2s;}
.focus-row.focus-current{border-left:5px solid var(--success-color);background:rgba(46,204,113,.07);}
.focus-time-col{width:84px;flex-shrink:0;font-weight:700;font-size:.95rem;color:var(--primary-color);}
.focus-bar-inner{border-radius:8px;height:42px;display:flex;align-items:center;padding:0 14px;font-weight:600;color:#fff;font-size:.9rem;flex:1;cursor:grab;user-select:none;}
.view-list{display:flex;flex-direction:column;gap:5px;}
.list-row{display:flex;align-items:center;gap:10px;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:10px;padding:11px 14px;cursor:grab;transition:all .2s;min-height:50px;user-select:none;}
.list-row:hover{background:var(--selected-bg);}
.list-row.list-current{border-left:5px solid var(--success-color);}
.list-check{width:22px;height:22px;border-radius:50%;border:2px solid var(--glass-border);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.8rem;transition:all .2s;cursor:pointer;}
.list-check.done{background:var(--success-color);border-color:var(--success-color);color:#fff;}
.view-compact{display:grid;grid-template-columns:repeat(auto-fill,minmax(132px,1fr));gap:7px;}
.compact-cell{border-radius:10px;padding:9px 11px;cursor:pointer;transition:all .2s;min-height:66px;display:flex;flex-direction:column;justify-content:space-between;border:1px solid var(--glass-border);}
.compact-empty{background:rgba(255,255,255,.4);border-style:dashed;}
.compact-busy{color:#fff;cursor:grab;}
.hm-grid{display:grid;grid-template-columns:68px repeat(7,1fr);gap:3px;min-width:480px;}
.hm-day-hdr{text-align:center;font-size:.78rem;font-weight:700;color:var(--primary-color);padding:5px 3px;background:rgba(255,107,107,.1);border-radius:5px 5px 0 0;}
.hm-time-lbl{font-size:.74rem;font-weight:700;color:var(--primary-color);display:flex;align-items:center;padding-right:7px;}
.hm-cell{min-height:34px;border-radius:5px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:600;border:1px solid rgba(255,255,255,.3);}
.view-radial{display:flex;justify-content:center;align-items:flex-start;padding:16px 0;flex-wrap:wrap;gap:20px;}
.radial-legend{display:flex;flex-direction:column;gap:7px;max-height:320px;overflow-y:auto;}
.radial-legend-item{display:flex;align-items:center;gap:7px;padding:5px 9px;border-radius:8px;background:rgba(255,255,255,.7);cursor:pointer;border:1px solid var(--glass-border);}
.prayer-cols-wrap{display:flex;gap:13px;overflow-x:auto;padding-bottom:8px;}
.prayer-col{flex:0 0 210px;background:rgba(255,255,255,.6);border:1px solid var(--glass-border);border-radius:14px;padding:12px;display:flex;flex-direction:column;gap:9px;min-height:360px;}
.prayer-col.drag-over{background:rgba(78,205,196,.12);border:2px dashed var(--secondary-color);}
.prayer-col-hdr{font-weight:700;font-size:.92rem;padding-bottom:9px;border-bottom:3px solid currentColor;display:flex;flex-direction:column;align-items:center;gap:3px;text-align:center;}
.weekly-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:13px;}
.weekly-day{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;padding:14px;text-align:center;box-shadow:var(--shadow);transition:transform .3s;min-height:210px;}
.weekly-day.is-today{border:2px solid var(--secondary-color);background:rgba(78,205,196,.05);}
.weekly-day.drag-over{background:rgba(78,205,196,.15);border:2px dashed var(--secondary-color);}
.weekly-day h3{margin-bottom:7px;color:var(--secondary-color);border-bottom:2px solid var(--glass-border);padding-bottom:7px;font-size:.9rem;}
.weekly-act{background:var(--primary-color);color:#fff;padding:8px;border-radius:7px;margin:5px 0;cursor:grab;display:flex;justify-content:space-between;align-items:center;font-size:.88rem;flex-direction:column;min-height:62px;gap:3px;user-select:none;}
.monthly-grid{display:grid;grid-template-columns:repeat(7,minmax(38px,1fr));gap:4px;min-width:280px;}
.monthly-day-hdr{text-align:center;font-weight:bold;padding:8px 2px;font-size:.84rem;color:var(--primary-color);background:rgba(255,107,107,.1);border-radius:5px;min-height:36px;display:flex;align-items:center;justify-content:center;}
.monthly-day{min-height:66px;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:5px;padding:5px;font-size:.76rem;position:relative;transition:transform .3s;cursor:pointer;}
.monthly-day.is-today-month{border:2px solid var(--secondary-color);background:rgba(78,205,196,.06);}
.monthly-day.empty{background:transparent;border:none;box-shadow:none;cursor:default;}
.monthly-date{font-weight:bold;margin-bottom:2px;text-align:center;color:var(--primary-color);}
.monthly-act{color:#fff;padding:3px;border-radius:3px;margin:2px 0;font-size:.66rem;cursor:grab;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-height:18px;user-select:none;}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:18px;margin-bottom:26px;}
.stat-card{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;padding:18px;text-align:center;box-shadow:var(--shadow);font-size:1.1rem;font-weight:500;min-height:90px;display:flex;flex-direction:column;justify-content:center;}
.pie-section{display:flex;justify-content:space-around;align-items:center;margin-bottom:26px;gap:26px;background:var(--glass-bg);padding:18px;border-radius:14px;box-shadow:var(--shadow);flex-wrap:wrap;}
.pie-container{width:140px;height:140px;border-radius:50%;position:relative;display:flex;justify-content:center;align-items:center;box-shadow:0 6px 14px rgba(0,0,0,.14);}
.pie-inner{text-align:center;background:var(--glass-bg);border-radius:50%;width:100px;height:100px;display:flex;justify-content:center;align-items:center;flex-direction:column;}
.pie-legend{display:flex;flex-direction:column;gap:10px;}
.pie-legend-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;background:rgba(255,255,255,.7);}
.pie-legend-dot{width:20px;height:20px;border-radius:50%;}
.check-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:13px;margin-bottom:22px;}
.check-stat-card{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;padding:18px;text-align:center;box-shadow:var(--shadow);min-height:108px;display:flex;flex-direction:column;justify-content:center;}
.check-stat-val{font-size:2.3rem;font-weight:700;margin:8px 0;}
.check-act-item{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;padding:18px;display:flex;align-items:center;gap:14px;box-shadow:var(--shadow);transition:all .3s;min-height:90px;}
.check-act-item.done{background:var(--success-color)!important;color:#fff;}
.check-act-item.missed{background:var(--error-color)!important;color:#fff;}
.check-cb{width:28px;height:28px;border-radius:50%;border:2px solid var(--glass-border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .3s;flex-shrink:0;font-size:1.1rem;}
.check-cb.checked{background:var(--on-time-color);border-color:var(--on-time-color);color:#fff;}
.cat-summary-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px;}
.cat-card{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;padding:18px;box-shadow:var(--shadow);transition:transform .3s;}
.cat-card:hover{transform:translateY(-4px);}
.cat-progress{height:9px;background:rgba(255,255,255,.3);border-radius:5px;margin-top:9px;overflow:hidden;}
.cat-progress-fill{height:100%;border-radius:5px;transition:width .5s ease;}
.tracker-row{display:flex;justify-content:space-between;padding:11px 0;border-bottom:1px dashed var(--glass-border);min-height:46px;align-items:center;}
.setting-section{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;margin-bottom:14px;box-shadow:var(--shadow);overflow:hidden;}
.setting-hdr{padding:16px 18px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;background:rgba(255,255,255,.7);border-bottom:1px solid var(--glass-border);min-height:64px;}
.setting-hdr:hover{background:rgba(255,255,255,.9);}
.setting-hdr h3{margin:0;font-size:1.1rem;display:flex;align-items:center;gap:9px;color:var(--primary-color);}
.setting-arrow{font-size:1.2rem;transition:transform .3s;color:var(--primary-color);}
.setting-arrow.open{transform:rotate(180deg);}
.setting-body{padding:0;max-height:0;overflow:hidden;transition:all .4s ease;}
.setting-body.open{padding:18px;max-height:2000px;overflow-y:auto;}
.setting-group{margin-bottom:14px;padding-bottom:14px;border-bottom:1px dashed var(--glass-border);}
.setting-group:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.setting-group label{display:block;margin-bottom:7px;font-weight:600;color:var(--primary-color);font-size:.95rem;}
.theme-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:12px;margin-top:12px;}
.theme-opt{padding:16px;border-radius:10px;border:2px solid var(--glass-border);cursor:pointer;text-align:center;transition:all .3s;background:var(--glass-bg);min-height:108px;display:flex;flex-direction:column;justify-content:center;align-items:center;}
.theme-opt:hover{transform:translateY(-4px);}
.theme-opt.selected{border-color:var(--primary-color);box-shadow:0 0 0 3px rgba(255,107,107,.2);}
.theme-preview{width:100%;height:54px;border-radius:7px;margin-bottom:9px;}
.toggle-switch{position:relative;display:inline-block;width:54px;height:28px;}
.toggle-switch input{opacity:0;width:0;height:0;}
.slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:#ccc;transition:.4s;border-radius:28px;}
.slider:before{position:absolute;content:"";height:22px;width:22px;left:3px;bottom:3px;background:#fff;transition:.4s;border-radius:50%;}
input:checked+.slider{background:var(--primary-color);}
input:checked+.slider:before{transform:translateX(26px);}
.color-picker{display:flex;flex-wrap:wrap;gap:9px;margin-top:9px;}
.color-opt{width:32px;height:32px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .2s;}
.color-opt:hover,.color-opt.selected{transform:scale(1.12);}
.color-opt.selected{border-color:var(--text-color);}
.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.78);display:flex;justify-content:center;align-items:center;z-index:1000;backdrop-filter:blur(4px);}
.modal-box{background:var(--glass-bg);padding:28px;border-radius:14px;width:90%;max-width:580px;max-height:88vh;overflow-y:auto;box-shadow:0 10px 28px rgba(0,0,0,.22);animation:popIn .35s ease;position:relative;}
.modal-box h3{margin-top:0;color:var(--primary-color);border-bottom:2px solid var(--glass-border);padding-bottom:9px;}
.modal-close{position:absolute;top:13px;right:13px;font-size:28px;color:var(--primary-color);cursor:pointer;background:none;border:none;padding:8px;transition:all .2s;}
.modal-close:hover{color:var(--secondary-color);transform:scale(1.2);}
.edit-form-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.78);display:flex;justify-content:center;align-items:center;z-index:1001;backdrop-filter:blur(4px);}
.edit-form-box{background:var(--glass-bg);padding:28px;border-radius:14px;width:92%;max-width:640px;max-height:86vh;overflow-y:auto;box-shadow:0 10px 28px rgba(0,0,0,.22);animation:popIn .35s ease;position:relative;}
.notification{position:fixed;top:18px;right:18px;background:var(--success-color);color:#fff;padding:13px 22px;border-radius:10px;box-shadow:0 4px 14px rgba(0,0,0,.22);display:flex;align-items:center;gap:9px;z-index:2000;transform:translateX(150%);transition:transform .5s cubic-bezier(.68,-.55,.265,1.55);}
.notification.show{transform:translateX(0);}
.zoom-controls{position:absolute;top:13px;right:13px;display:flex;gap:8px;z-index:10;}
.zoom-btn{width:40px;height:40px;background:var(--primary-color);color:#fff;border:none;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;box-shadow:var(--shadow);transition:all .2s;}
.zoom-ind{position:absolute;bottom:13px;right:13px;background:var(--glass-bg);padding:8px 12px;border-radius:18px;font-size:.9rem;font-weight:600;color:var(--primary-color);box-shadow:var(--shadow);z-index:10;}
/* AI */
.ai-subnav{display:flex;margin-bottom:0;background:var(--glass-bg);border-radius:12px 12px 0 0;padding:7px;box-shadow:var(--shadow);overflow-x:auto;min-height:52px;align-items:center;gap:4px;border-bottom:2px solid var(--glass-border);}
.ai-subbtn{padding:10px 17px;background:none;border:none;cursor:pointer;font-size:.9rem;font-weight:600;color:var(--tab-inactive);position:relative;transition:all .3s;border-radius:10px;flex-shrink:0;min-height:40px;white-space:nowrap;}
.ai-subbtn:hover{background:rgba(99,102,241,.1);}
.ai-subbtn.active{color:var(--ai-color);background:rgba(99,102,241,.14);}
.ai-subbtn.active::after{content:'';position:absolute;bottom:-7px;left:50%;transform:translateX(-50%);width:80%;height:3px;background:var(--ai-color);border-radius:2px;}
.ai-subcontent{display:none;animation:fadeIn .4s ease;background:var(--glass-bg);border:1px solid var(--glass-border);border-top:none;border-radius:0 0 12px 12px;box-shadow:var(--shadow);}
.ai-subcontent.active{display:block;}
.ai-chat-wrapper{display:flex;flex-direction:column;height:600px;}
.ai-chat-header{padding:15px 18px;background:var(--ai-gradient);color:#fff;display:flex;align-items:center;gap:11px;}
.ai-chat-avatar{width:42px;height:42px;background:rgba(255,255,255,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;}
.ai-chat-title h3{margin:0;font-size:1.05rem;color:#fff;}
.ai-chat-title p{margin:0;font-size:.74rem;opacity:.85;}
.ai-status-dot{width:9px;height:9px;border-radius:50%;background:#4ade80;box-shadow:0 0 5px #4ade80;animation:pulse 2s infinite;}
.ai-messages{flex:1;overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:13px;background:rgba(248,250,252,.8);}
.ai-msg{display:flex;gap:9px;align-items:flex-start;max-width:88%;}
.ai-msg.user{align-self:flex-end;flex-direction:row-reverse;}
.ai-msg.assistant{align-self:flex-start;}
.ai-msg-av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0;box-shadow:0 2px 5px rgba(0,0,0,.14);}
.ai-msg.assistant .ai-msg-av{background:var(--ai-gradient);color:#fff;}
.ai-msg.user .ai-msg-av{background:var(--primary-color);color:#fff;}
.ai-bubble{padding:11px 14px;border-radius:14px;font-size:.88rem;line-height:1.55;box-shadow:0 2px 7px rgba(0,0,0,.08);max-width:100%;word-break:break-word;}
.ai-msg.assistant .ai-bubble{background:#fff;border-radius:4px 14px 14px 14px;color:var(--text-color);}
.ai-msg.user .ai-bubble{background:var(--ai-gradient);color:#fff;border-radius:14px 4px 14px 14px;}
.ai-msg-time{font-size:.64rem;opacity:.5;margin-top:3px;display:block;}
.ai-typing{display:flex;align-items:center;gap:5px;padding:11px 14px;background:#fff;border-radius:4px 14px 14px 14px;box-shadow:0 2px 7px rgba(0,0,0,.08);}
.ai-typing-dot{width:7px;height:7px;border-radius:50%;background:var(--ai-color);animation:aiTyping 1.4s infinite ease-in-out both;}
.ai-typing-dot:nth-child(2){animation-delay:.16s;}
.ai-typing-dot:nth-child(3){animation-delay:.32s;}
.ai-input-area{padding:12px 14px;background:#fff;border-top:1px solid var(--glass-border);display:flex;gap:9px;align-items:flex-end;}
.ai-textarea{flex:1;padding:10px 13px;border:2px solid var(--glass-border);border-radius:12px;font-family:'Poppins',sans-serif;font-size:.9rem;resize:none;min-height:44px;max-height:130px;outline:none;transition:border-color .2s;margin:0;background:#fff;}
.ai-textarea:focus{border-color:var(--ai-color);box-shadow:0 0 0 3px rgba(99,102,241,.14);}
.ai-send-btn{width:44px;height:44px;background:var(--ai-gradient);border:none;border-radius:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff;transition:all .2s;flex-shrink:0;}
.ai-send-btn:hover{transform:translateY(-2px);}
.ai-send-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.ai-quick-prompts{display:flex;gap:8px;flex-wrap:wrap;padding:10px 14px 0;background:#fff;}
.ai-quick-btn{padding:5px 11px;background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.24);border-radius:18px;font-size:.74rem;cursor:pointer;color:var(--ai-color);font-weight:600;transition:all .2s;font-family:'Poppins',sans-serif;}
.ai-quick-btn:hover{background:rgba(99,102,241,.2);}
.ai-breakdown-wrap{padding:18px;}
.ai-gen-btn{padding:9px 20px;background:var(--ai-gradient);color:#fff;border:none;border-radius:10px;cursor:pointer;font-weight:700;font-size:.86rem;display:flex;align-items:center;gap:7px;transition:all .2s;}
.ai-gen-btn:disabled{opacity:.6;cursor:not-allowed;}
.ai-output{background:#fff;border:1px solid var(--glass-border);border-radius:12px;padding:18px;min-height:180px;font-size:.9rem;line-height:1.7;word-break:break-word;}
.ai-output.loading{display:flex;align-items:center;justify-content:center;gap:11px;color:var(--ai-color);font-weight:600;}
.ai-spinner{width:22px;height:22px;border:3px solid rgba(99,102,241,.2);border-top-color:var(--ai-color);border-radius:50%;animation:spin .8s linear infinite;}
.ai-controls-wrap{padding:18px;}
.ai-cmd-row{display:flex;gap:9px;margin-bottom:14px;}
.ai-cmd-input{flex:1;padding:13px 14px;border:2px solid rgba(99,102,241,.3);border-radius:12px;font-family:'Poppins',sans-serif;font-size:.9rem;background:#fff;outline:none;transition:border-color .2s;margin:0;}
.ai-cmd-input:focus{border-color:var(--ai-color);}
.ai-run-btn{padding:13px 20px;background:var(--ai-gradient);color:#fff;border:none;border-radius:12px;cursor:pointer;font-weight:700;font-size:.9rem;white-space:nowrap;transition:all .2s;}
.ai-run-btn:disabled{opacity:.5;cursor:not-allowed;}
.ai-result-box{background:#fff;border:1px solid var(--glass-border);border-radius:12px;padding:14px;min-height:70px;font-size:.86rem;line-height:1.6;margin-bottom:14px;word-break:break-word;}
.ai-chips{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.ai-chip{padding:7px 14px;background:rgba(99,102,241,.1);border:1.5px solid rgba(99,102,241,.28);border-radius:18px;cursor:pointer;font-size:.78rem;font-weight:600;color:var(--ai-color);transition:all .2s;font-family:'Poppins',sans-serif;}
.ai-chip:hover{background:rgba(99,102,241,.2);}
.ai-status-bar{display:flex;align-items:center;gap:7px;padding:7px 12px;border-radius:8px;font-size:.82rem;font-weight:600;margin-bottom:11px;}
.ai-status-bar.ok{background:rgba(46,204,113,.1);color:var(--success-color);border:1px solid var(--success-color);}
.ai-status-bar.error{background:rgba(255,107,107,.1);color:var(--error-color);border:1px solid var(--error-color);}
.ai-status-bar.idle{background:rgba(0,0,0,.05);color:var(--text-color);border:1px solid var(--glass-border);}
.act-table{width:100%;border-collapse:collapse;font-size:.82rem;margin-top:7px;}
.act-table th{background:rgba(99,102,241,.1);padding:7px 9px;text-align:left;font-weight:700;color:var(--ai-color);border-bottom:2px solid rgba(99,102,241,.2);}
.act-table td{padding:7px 9px;border-bottom:1px solid var(--glass-border);word-break:break-word;}
.fb-status{display:flex;align-items:center;gap:9px;padding:9px 13px;border-radius:10px;margin-bottom:11px;font-size:.86rem;font-weight:600;}
.fb-status.connected{background:rgba(46,204,113,.1);color:var(--success-color);border:1px solid var(--success-color);}
.fb-status.disconnected{background:rgba(255,107,107,.1);color:var(--error-color);border:1px solid var(--error-color);}
.fb-status.syncing{background:rgba(255,159,67,.1);color:var(--warning-color);border:1px solid var(--warning-color);}
.fb-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.fb-dot.connected{background:var(--success-color);}
.fb-dot.disconnected{background:var(--error-color);}
.fb-dot.syncing{background:var(--warning-color);}
.fb-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.fb-grid input{margin:0;font-size:.82rem;padding:9px;}
.sync-log{background:rgba(0,0,0,.04);border-radius:8px;padding:11px;font-size:.78rem;font-family:monospace;max-height:110px;overflow-y:auto;margin-top:9px;word-break:break-all;}
.file-upload-lbl{display:inline-flex;padding:12px 24px;background:var(--primary-color);color:#fff;border-radius:10px;cursor:pointer;transition:all .3s;font-weight:600;box-shadow:0 4px 9px rgba(255,107,107,.3);min-height:46px;align-items:center;justify-content:center;}
.file-upload-lbl:hover{background:var(--button-hover);}
.file-upload-lbl input[type="file"]{display:none;}
.data-io-btns{display:flex;gap:12px;flex-wrap:wrap;margin-top:12px;}
.repeat-toggle-card{background:rgba(78,205,196,.07);border:1.5px solid var(--secondary-color);border-radius:12px;padding:13px 16px;margin-top:3px;}
.repeat-toggle-lbl{display:flex;align-items:center;gap:11px;font-weight:700;font-size:.95rem;cursor:pointer;color:var(--secondary-color);}
.repeat-toggle-lbl input[type="checkbox"]{width:19px;height:19px;accent-color:var(--secondary-color);cursor:pointer;flex-shrink:0;margin:0;}
.import-status{margin-top:12px;padding:11px;border-radius:8px;font-weight:600;text-align:center;}
.import-status.success{background:rgba(46,204,113,.18);color:var(--success-color);border:1px solid var(--success-color);}
.import-status.error{background:rgba(255,107,107,.18);color:var(--error-color);border:1px solid var(--error-color);}
.voice-btn{width:52px;height:52px;border-radius:50%;background:var(--ai-gradient);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#fff;box-shadow:0 4px 14px rgba(99,102,241,.4);transition:all .3s;flex-shrink:0;}
.voice-btn:hover{transform:scale(1.08);}
.voice-btn.listening{background:linear-gradient(135deg,#ef4444,#dc2626);animation:voicePulse 1s infinite;}
.voice-transcript{background:rgba(99,102,241,.06);border:1.5px solid rgba(99,102,241,.2);border-radius:10px;padding:11px 14px;font-size:.88rem;min-height:44px;font-style:italic;color:var(--text-color);word-break:break-word;}
.wa-card{background:linear-gradient(135deg,rgba(37,211,102,.08),rgba(18,140,126,.08));border:1.5px solid rgba(37,211,102,.3);border-radius:14px;padding:18px;margin-bottom:14px;}
.wa-msg-preview{background:#fff;border-radius:14px;border-top-left-radius:0;padding:12px 14px;font-size:.88rem;box-shadow:0 2px 7px rgba(0,0,0,.08);margin:9px 0;max-width:85%;word-break:break-word;}
/* WhatsApp Receive */
.wa-receive-card{background:linear-gradient(135deg,rgba(37,211,102,.05),rgba(18,140,126,.05));border:1.5px solid rgba(37,211,102,.25);border-radius:14px;padding:18px;margin-bottom:14px;}
.wa-msg-in{background:#e9f5ec;border-radius:0 14px 14px 14px;padding:12px 14px;font-size:.88rem;box-shadow:0 2px 7px rgba(0,0,0,.06);margin:6px 0;max-width:85%;word-break:break-word;border:1px solid rgba(37,211,102,.2);}
.wa-simulate-btn{background:linear-gradient(135deg,#25D366,#128C7E);color:#fff;border:none;border-radius:10px;padding:10px 18px;cursor:pointer;font-family:'Poppins',sans-serif;font-weight:600;font-size:.88rem;display:inline-flex;align-items:center;gap:7px;transition:all .2s;}
.wa-simulate-btn:hover{transform:translateY(-2px);}
.collab-row{display:flex;align-items:center;gap:12px;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:10px;padding:13px 16px;box-shadow:var(--shadow);transition:transform .2s;}
.share-link-box{background:rgba(99,102,241,.06);border:1.5px solid rgba(99,102,241,.2);border-radius:10px;padding:12px 14px;font-family:monospace;font-size:.84rem;word-break:break-all;color:var(--ai-color);}
.prompt-block{background:rgba(99,102,241,.04);border:1.5px solid rgba(99,102,241,.2);border-radius:12px;padding:16px;margin-bottom:12px;}
.prompt-tag{display:inline-flex;padding:4px 10px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);border-radius:18px;font-size:.76rem;font-weight:600;color:var(--ai-color);cursor:pointer;margin:3px;transition:all .2s;}
.prompt-tag:hover{background:rgba(99,102,241,.25);}
/* Webhook/Zapier */
.webhook-log{background:#f8f9fa;border:1px solid var(--glass-border);border-radius:9px;padding:10px;font-size:.76rem;font-family:monospace;max-height:120px;overflow-y:auto;margin-top:9px;word-break:break-all;}
@keyframes fadeIn{from{opacity:0;transform:translateY(9px);}to{opacity:1;transform:translateY(0);}}
@keyframes popIn{0%{transform:scale(.9);opacity:0;}100%{transform:scale(1);opacity:1;}}
@keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.05);}}
@keyframes spin{to{transform:rotate(360deg);}}
@keyframes aiTyping{0%,80%,100%{transform:scale(0);}40%{transform:scale(1);}}
@keyframes voicePulse{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.4);}50%{box-shadow:0 0 0 12px rgba(239,68,68,0);}}
@media(max-width:768px){
.date-row{grid-template-columns:1fr 1fr;}
.weekly-grid{grid-template-columns:1fr;}
.pie-section{flex-direction:column;align-items:center;}
.tab-btn{min-width:64px;}
.monthly-grid{grid-template-columns:repeat(7,minmax(26px,1fr));gap:2px;}
.monthly-day{min-height:44px;padding:2px;}
.cat-summary-grid{grid-template-columns:1fr;}
.ai-chat-wrapper{height:480px;}
.fb-grid{grid-template-columns:1fr;}
}
@media(min-width:769px){.tab-btn .tab-label{display:block;}}
</style>
