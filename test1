  voiceRecognition=new SR();
  voiceRecognition.continuous=false;voiceRecognition.interimResults=true;
  voiceRecognition.lang=settings.voiceLang||'en-US';
  voiceRecognition.onresult=e=>{
    let t='';for(let i=e.resultIndex;i<e.results.length;i++)t+=e.results[i][0].transcript;
    const tr=document.getElementById('voiceTranscript');if(tr)tr.textContent=t;
    const pb=document.getElementById('voiceProcessBtn');
    if(e.results[e.results.length-1].isFinal&&pb)pb.style.display='inline-flex';
  };
  voiceRecognition.onend=()=>{
    voiceListening=false;
    const vb=document.getElementById('voiceBtn');if(vb){vb.classList.remove('listening');vb.textContent='🎤';}
  };
  voiceRecognition.onerror=e=>{
    voiceListening=false;
    const tr=document.getElementById('voiceTranscript');if(tr)tr.textContent='Error: '+e.error;
  };
}

function toggleVoiceInput(){
  if(!voiceRecognition){notify('Voice not supported in this browser','var(--error-color)');return;}
  voiceRecognition.lang=settings.voiceLang||'en-US';
  if(voiceListening){voiceRecognition.stop();voiceListening=false;}
  else{
    voiceRecognition.start();voiceListening=true;
    const vb=document.getElementById('voiceBtn');if(vb){vb.classList.add('listening');vb.textContent='🔴';}
    const tr=document.getElementById('voiceTranscript');if(tr)tr.textContent='Listening…';
  }
}

function processVoiceCommand(){
  const t=document.getElementById('voiceTranscript')?.textContent;
  if(!t||t==='Listening…'||t.startsWith('Click mic'))return;
  sendQuickPrompt(t);
  const pb=document.getElementById('voiceProcessBtn');if(pb)pb.style.display='none';
}

function toggleChatVoice(){
  if(!voiceRecognition){notify('Voice not supported','var(--error-color)');return;}
  voiceRecognition.lang=settings.voiceLang||'en-US';
  const btn=document.getElementById('chatVoiceBtn');
  const st=document.getElementById('chatVoiceStatus');
  if(chatVoiceListening){
    voiceRecognition.stop();chatVoiceListening=false;
    if(btn){btn.classList.remove('listening');btn.textContent='🎤';}
    if(st)st.textContent='Voice ready';
  } else {
    chatVoiceListening=true;
    if(btn){btn.classList.add('listening');btn.textContent='🔴';}
    if(st)st.textContent='Listening…';
    const origHandler=voiceRecognition.onresult;
    voiceRecognition.onresult=e=>{
      let t='';for(let i=e.resultIndex;i<e.results.length;i++)t+=e.results[i][0].transcript;
      const inp=document.getElementById('aiChatInput');if(inp)inp.value=t;
      if(e.results[e.results.length-1].isFinal){
        sendAIChat();chatVoiceListening=false;
        if(btn){btn.classList.remove('listening');btn.textContent='🎤';}
        if(st)st.textContent='Voice ready';
        voiceRecognition.onresult=origHandler;
      }
    };
    voiceRecognition.start();
  }
}

function testVoice(){
  const r=document.getElementById('voiceTestResult');
  if(!('webkitSpeechRecognition' in window||'SpeechRecognition' in window)){
    if(r){r.innerHTML='';const err=document.createElement('span');err.style.color='var(--error-color)';err.textContent='❌ Voice recognition not supported in this browser';r.appendChild(err);}
    return;
  }
  if(r){r.innerHTML='';const ok=document.createElement('span');ok.style.color='var(--success-color)';ok.textContent='✅ Voice recognition available';r.appendChild(ok);}
  if('speechSynthesis' in window){
    const u=new SpeechSynthesisUtterance('Voice is working!');window.speechSynthesis.speak(u);
  }
}

// =====================================================================
// TIME DISPLAY
// =====================================================================
function updateTimeDisplay(){
  const el=document.getElementById('currentTimeDisplay');if(!el)return;
  const now=new Date();
  el.textContent=`${currentDay} • ${now.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})} • ${now.toLocaleDateString()}`;
}

// =====================================================================
// INIT
// =====================================================================
document.addEventListener('DOMContentLoaded',()=>{
  'use strict';
  buildMainTabs();
  buildSubNavs();
  populateCatSelects();
  loadPlan();

  // Set today defaults
  const today=new Date();
  currentDay=today.toLocaleDateString('en-US',{weekday:'long'});
  const daySelect=document.getElementById('daySelect');if(daySelect)daySelect.value=currentDay;
  const checkDay=document.getElementById('checkDaySelect');if(checkDay)checkDay.value=currentDay;
  const quickDate=document.getElementById('quickDate');if(quickDate)quickDate.value=todayISO();
  const quickTime=document.getElementById('quickTime');if(quickTime){
    const h=today.getHours();const m=Math.ceil(today.getMinutes()/15)*15;
    quickTime.value=`${String(h).padStart(2,'0')}:${String(m>=60?m-60:m).padStart(2,'0')}`;
  }

  // Open first tabs
  openMainTab('activities');
  openActSub('quick');
  openCalSub('daily');

  // Init voice
  initVoiceRecognition();

  // Apply saved theme
  if(settings.theme&&settings.theme!=='default')document.body.dataset.theme=settings.theme;

  // Time display
  updateTimeDisplay();setInterval(updateTimeDisplay,30000);

  // Stats
  calcStats();updatePie();

  // AI system prompt default
  const asp=document.getElementById('aiSystemPrompt');
  if(asp&&!asp.value)asp.value=settings.aiSystemPrompt||defaultAIPrompt();

  // Keyboard shortcut: Escape closes modals
  document.addEventListener('keydown',e=>{
    if(e.key==='Escape'){
      ['detailsModal','editModal','shareModal','waCoachModal','wakeModal','sleepModal'].forEach(id=>{
        const el=document.getElementById(id);if(el)el.style.display='none';
      });
    }
  });

  // Close modals on overlay click
  ['detailsModal','shareModal','waCoachModal','wakeModal','sleepModal'].forEach(id=>{
    const el=document.getElementById(id);if(!el)return;
    el.addEventListener('click',e=>{if(e.target===el)el.style.display='none';});
  });
});
</script>
