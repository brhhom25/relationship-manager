function findFreeSlots(){
  const dayF=document.getElementById('freeDay').value;
  const minDur=parseInt(document.getElementById('freeDur').value)||30;
  const fromMin2=toMin(document.getElementById('freeFrom').value||'08:00');
  const toMin2=toMin(document.getElementById('freeTo').value||'22:00');
  const results=document.getElementById('freeResults');results.innerHTML='';
  const targetDays=dayF==='all'?DAYS:[dayF];let slots=[];
  targetDays.forEach(day=>{
    const acts=(activities[day]||[]).slice().sort((a,b)=>toMin(a.time)-toMin(b.time));
    let prev=fromMin2;
    acts.forEach(act=>{const as=toMin(act.time);const ae=as+act.duration;if(as>prev&&as-prev>=minDur)slots.push({day,start:prev,end:as,dur:as-prev});if(ae>prev)prev=ae;});
    if(toMin2>prev&&toMin2-prev>=minDur)slots.push({day,start:prev,end:toMin2,dur:toMin2-prev});
  });
  if(!slots.length){const em=document.createElement('div');em.style.cssText='opacity:.6;text-align:center;padding:18px;';em.textContent='No free slots found.';results.appendChild(em);return;}
  slots.sort((a,b)=>b.dur-a.dur).slice(0,12).forEach(s=>{
    const card=document.createElement('div');card.style.cssText='background:rgba(107,91,149,.1);border:1.5px solid var(--free-time-color);border-radius:11px;padding:13px 16px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;';
    const h=Math.floor(s.dur/60),m=s.dur%60;
    const info=document.createElement('div');
    const day=document.createElement('div');day.style.cssText='font-weight:700;color:var(--free-time-color);';day.textContent=s.day;
    const range=document.createElement('div');range.style.fontSize='.9rem';range.textContent=`${toTime(s.start)} – ${toTime(s.end)}`;
    info.appendChild(day);info.appendChild(range);
    const dur=document.createElement('div');dur.style.cssText='font-weight:700;color:var(--free-time-color);';dur.textContent=`${h>0?h+'h ':''}${m>0?m+'m':''} free`;
    const addBtn=document.createElement('button');addBtn.className='btn btn-secondary btn-sm';addBtn.textContent='+ Add Here';
    addBtn.addEventListener('click',()=>{currentDay=s.day;const ds=document.getElementById('daySelect');if(ds)ds.value=s.day;const qt=document.getElementById('quickTime');if(qt)qt.value=toTime(s.start);openMainTab('activities');openActSub('quick');});
    card.appendChild(info);card.appendChild(dur);card.appendChild(addBtn);results.appendChild(card);
  });
}

