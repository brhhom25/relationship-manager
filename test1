}
function moveDragGhost(evt){
  if(!dragState.active)return;
  const x=evt.touches?evt.touches[0].clientX:evt.clientX;
  const y=evt.touches?evt.touches[0].clientY:evt.clientY;
  const g=document.getElementById('dragGhost');
  g.style.left=(x+12)+'px';g.style.top=(y-20)+'px';
}
function endDrag(evt){
  if(!dragState.active)return;
  document.getElementById('dragGhost').style.display='none';
  document.removeEventListener('mousemove',moveDragGhost);
  document.removeEventListener('touchmove',moveDragGhost);
  document.removeEventListener('mouseup',endDrag);
  document.removeEventListener('touchend',endDrag);
  const cx=evt.changedTouches?evt.changedTouches[0].clientX:evt.clientX;
  const cy=evt.changedTouches?evt.changedTouches[0].clientY:evt.clientY;
  const el=document.elementFromPoint(cx,cy);
  if(el){
    const dp=el.closest('[data-drop-day]');
    if(dp){
      const targetDay=dp.dataset.dropDay;
      const targetTime=dp.dataset.dropTime;
      const src=activities[dragState.day];
      if(src&&src[dragState.idx]){
        const act=src[dragState.idx];
        if(dragState.day!==targetDay){
          src.splice(dragState.idx,1);
          if(!activities[targetDay])activities[targetDay]=[];
          const moved={...act};if(targetTime)moved.time=targetTime;
          activities[targetDay].push(moved);
        } else if(targetTime){
          act.time=targetTime;
        }
        DAYS.forEach(d=>sortDay(d));renderAll();savePlan();
        notify('Activity moved!');
      }
    }
  }
  document.querySelectorAll('.drag-over').forEach(e=>e.classList.remove('drag-over'));
  dragState={active:false,day:null,idx:null};
}
function makeActivityDraggable(el,day,idx){
  el.draggable=true;
  el.addEventListener('dragstart',e=>{e.dataTransfer.effectAllowed='move';dragState={active:true,day,idx};setTimeout(()=>el.classList.add('dragging'),0);});
  el.addEventListener('dragend',()=>el.classList.remove('dragging'));
  el.addEventListener('mousedown',e=>{if(e.button!==0)return;startDrag(day,idx,e);});
  el.addEventListener('touchstart',e=>startDrag(day,idx,e),{passive:false});
}
function makeDropZone(el,targetDay,targetTime){
  el.dataset.dropDay=targetDay;
  if(targetTime)el.dataset.dropTime=targetTime;
  el.addEventListener('dragover',e=>{e.preventDefault();el.classList.add('drag-over');});
  el.addEventListener('dragleave',()=>el.classList.remove('drag-over'));
  el.addEventListener('drop',e=>{
    e.preventDefault();e.stopPropagation();el.classList.remove('drag-over');
    if(dragState.day===null||dragState.idx===null)return;
    const act=activities[dragState.day]&&activities[dragState.day][dragState.idx];if(!act)return;
    if(dragState.day!==targetDay){
      activities[dragState.day].splice(dragState.idx,1);
      if(!activities[targetDay])activities[targetDay]=[];
      const moved={...act};if(targetTime)moved.time=targetTime;
      activities[targetDay].push(moved);
    } else if(targetTime){act.time=targetTime;}
    DAYS.forEach(d=>sortDay(d));renderAll();savePlan();notify('Activity moved!');
    dragState={active:false,day:null,idx:null};
  });
}

