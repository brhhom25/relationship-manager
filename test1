function renderCatSummary(){
  const dayFilter=document.getElementById('catSummaryDaySelect')?.value||'all';
  const grid=document.getElementById('catSummaryGrid');if(!grid)return;grid.innerHTML='';
  const catData={};const targetDays=dayFilter==='all'?DAYS:[dayFilter];
  targetDays.forEach(day=>{(activities[day]||[]).forEach(act=>{const c=act.category||'Other';if(!catData[c])catData[c]={total:0,count:0,completed:0};catData[c].total+=act.duration;catData[c].count++;const key=`${day}_${act.activity}_${act.time}`;if(actTracking[key]?.completed)catData[c].completed++;});});
