function quickAdd(){
  const rawName=document.getElementById('quickName').value;
  const name=sanitizeText(rawName,120);
  const time=document.getElementById('quickTime').value;
  const dur=Math.max(1,Math.min(1440,parseInt(document.getElementById('quickDur').value)||30));
  const cat=document.getElementById('quickCat').value;
  const dateVal=document.getElementById('quickDate').value;
  const repeatEnabled=document.getElementById('quickRepeatEnabled').checked;
  const repeatType=repeatEnabled?document.getElementById('quickRepeatType').value:'none';

  if(!name){notify('Enter an activity name!','var(--error-color)');return;}
  if(!time){notify('Select a time!','var(--error-color)');return;}
  if(!dateVal){notify('Select a date!','var(--error-color)');return;}
  if(!/^\d{4}-\d{2}-\d{2}$/.test(dateVal)){notify('Invalid date!','var(--error-color)');return;}
  if(!/^\d{2}:\d{2}$/.test(time)){notify('Invalid time!','var(--error-color)');return;}

  const dateObj=new Date(dateVal+'T00:00:00');
  const targetDay=DOW[dateObj.getDay()];
  const specificDate=repeatType==='none'?dateVal:null;
  const act={category:cat,activity:name,time,duration:dur,
    color:CAT_COLORS[cat]||'#FF6B6B',repeat:repeatType,specificDate,date:dateVal};
  if(!activities[targetDay])activities[targetDay]=[];
  activities[targetDay].push(act);
  if(repeatType==='daily'){
    DAYS.forEach(d=>{if(d!==targetDay){if(!activities[d])activities[d]=[];activities[d].push({...act,specificDate:null});}});
  }
  DAYS.forEach(d=>sortDay(d));
  currentDay=targetDay;
  const ds=document.getElementById('daySelect');if(ds)ds.value=targetDay;
  const today=new Date();today.setHours(0,0,0,0);
  currentDayOffset=Math.round((dateObj-today)/(864e5));
  renderAll();notify((isEvent(act)?'🎉 ':'')+name+' added to '+targetDay,'','Activity Added!');
  document.getElementById('quickName').value='';
  document.getElementById('quickRepeatEnabled').checked=false;
  document.getElementById('quickRepeatWrap').style.display='none';
  savePlan();awardXP(5);
}

function renderAll(){
  updateDayNav();renderCalendarView();renderWeeklyView();
  calcStats();updatePie();renderMonthly();renderCatSummary();
  renderCheckTab();refreshAIOverview();refreshActTable();
}

function deleteActivity(day,idx){
  if(!activities[day])return;
  activities[day].splice(idx,1);
  renderAll();savePlan();notify('Activity deleted');
}

function toggleDone(day,idx){
  const act=(activities[day]||[])[idx];if(!act)return;
  const key=`${day}_${act.activity}_${act.time}`;
  if(!actTracking[key])actTracking[key]={};
  const now=new Date();const cur=now.getHours()*60+now.getMinutes();const sched=toMin(act.time);
  if(actTracking[key].completed){
    actTracking[key].completed=false;actTracking[key].status=null;
  } else {
    actTracking[key].completed=true;
    actTracking[key].completedTime=now.toISOString();
    actTracking[key].status=cur<=sched+5?'on-time':cur<=sched+30?'late':'missed';
    awardXP(10);checkBadges();
  }
  savePlan();
}

