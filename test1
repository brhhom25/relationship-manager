<body>
<div class="container">

<!-- Notification -->
<div class="notification" id="notif">
  <span id="notifIcon">✓</span>
  <div><div id="notifTitle" style="font-weight:700;font-size:1.1rem;"></div><div id="notifMsg"></div></div>
</div>

<!-- Drag Ghost -->
<div class="drag-ghost" id="dragGhost" style="display:none;"></div>

<!-- ===== EDIT MODAL ===== -->
<div class="edit-form-overlay" id="editModal" style="display:none;">
  <div class="edit-form-box">
    <button class="modal-close" onclick="closeEditForm()">×</button>
    <h3>✏️ Edit Activity</h3>
    <label>Category</label><select id="editCategory"></select>
    <label>Activity Name</label><input type="text" id="editActivity" maxlength="120">
    <label>Date</label><input type="date" id="editDate">
    <label>Start Time</label><input type="time" id="editTime">
    <label>Duration (min)</label><input type="number" id="editDuration" min="1" max="1440">
    <label>Color</label><div class="color-picker" id="editColorPicker"></div><input type="hidden" id="editSelectedColor">
    <label>Repeat</label>
    <select id="editRepeat">
      <option value="none">No Repeat</option><option value="daily">Every Day</option>
      <option value="weekly">Every Week</option><option value="monthly">Every Month</option>
    </select>
    <label>Description</label><textarea id="editDescription" maxlength="500"></textarea>
    <label>Goal</label><input type="text" id="editGoal" maxlength="200">
    <label>Location</label><input type="text" id="editLocation" maxlength="200">
    <div style="margin-top:12px;background:rgba(255,255,255,.7);border-radius:10px;padding:13px;">
      <h4 style="margin:0 0 9px;color:var(--primary-color);">Apply to:</h4>
      <label style="display:flex;align-items:center;gap:9px;margin-bottom:7px;"><input type="radio" name="editScope" value="this" checked> Only this</label>
      <label style="display:flex;align-items:center;gap:9px;"><input type="radio" name="editScope" value="all"> All occurrences</label>
    </div>
    <div style="display:flex;gap:12px;margin-top:18px;">
      <button class="btn btn-primary" onclick="saveEditedActivity()">💾 Save</button>
      <button class="btn btn-danger" onclick="closeEditForm()">✕ Cancel</button>
    </div>
  </div>
</div>

<!-- ===== DETAILS MODAL ===== -->
<div class="modal-overlay" id="detailsModal" style="display:none;">
  <div class="modal-box">
    <button class="modal-close" onclick="closeDetails()">×</button>
    <div id="detailsContent"></div>
    <div id="detailsReview"></div>
    <div style="display:flex;gap:7px;margin-top:18px;flex-wrap:wrap;">
      <button class="btn btn-success btn-sm" id="detailsDoneBtn" onclick="markDoneFromDetails()">✅ Mark Done</button>
      <button class="btn btn-warning btn-sm" onclick="editFromDetails()">✏️ Edit</button>
      <button class="btn btn-secondary btn-sm" onclick="shareFromDetails()">📨 Share</button>
      <button class="btn btn-sm" style="background:#4285F4;color:#fff;" onclick="addToGCal()">📅 GCal</button>
      <button class="btn btn-wa btn-sm" onclick="shareViaWhatsApp()">💬 WhatsApp</button>
      <button class="btn btn-danger btn-sm" onclick="deleteFromDetails()">🗑️ Delete</button>
    </div>
  </div>
</div>

<!-- ===== SHARE MODAL ===== -->
<div class="modal-overlay" id="shareModal" style="display:none;">
  <div class="modal-box">
    <button class="modal-close" onclick="document.getElementById('shareModal').style.display='none'">×</button>
    <h3>📨 Share Activity</h3>
    <pre id="shareBody" style="white-space:pre-wrap;font-family:inherit;background:rgba(0,0,0,.04);padding:13px;border-radius:9px;word-break:break-word;"></pre>
    <div style="display:flex;gap:9px;margin-top:14px;flex-wrap:wrap;">
      <button class="btn btn-secondary btn-sm" onclick="copyShareBody()">📋 Copy</button>
      <button class="btn btn-wa btn-sm" onclick="openWAWithShareBody()">💬 WhatsApp</button>
      <button class="btn btn-primary btn-sm" onclick="emailShareBody()">📧 Email</button>
    </div>
  </div>
</div>

<!-- ===== WA COACH MODAL ===== -->
<div class="modal-overlay" id="waCoachModal" style="display:none;">
  <div class="modal-box">
    <button class="modal-close" onclick="document.getElementById('waCoachModal').style.display='none'">×</button>
    <h3>💬 WhatsApp Coach Message</h3>
    <div id="waCoachPreview" class="wa-msg-preview"></div>
