function defaultAIPrompt(){
  return`You are an intelligent AI Life Coach and Schedule Manager. You help the user manage their daily planner.\n\nUser schedule:\n{schedule}\n\nToday (${'{today}'}):\n{today}\n\nStats: {stats}\n\nYou can perform schedule actions. When adding, editing, or deleting activities respond with JSON action blocks:\n<action>{"type":"add","day":"Monday","activity":"Morning Yoga","time":"06:00","duration":30,"category":"Health and Fitness"}</action>\n<action>{"type":"delete","day":"Monday","activity":"Morning Yoga","time":"06:00"}</action>\n<action>{"type":"mark_done","day":"Monday","activity":"Morning Yoga","time":"06:00"}</action>\n\nBe warm, helpful, and concise. Language: {language}.`;
}

function buildAIContext(){
  let sched='';DAYS.forEach(day=>{const acts=activities[day]||[];if(acts.length){sched+=`${day}: `;sched+=acts.map(a=>`${a.activity}@${a.time}(${a.duration}min)`).join(', ')+'\n';}});
  const today=currentDay;const todayActs=activities[today]||[];
  const done=todayActs.filter(a=>(actTracking[`${today}_${a.activity}_${a.time}`]||{}).completed).length;
  const stats=`${done}/${todayActs.length} done today, Level ${gamification.level}, ${gamification.xp}XP`;
  let prompt=settings.aiSystemPrompt||defaultAIPrompt();
  prompt=prompt
    .replace('{schedule}',sched||'Empty')
    .replace('{today}',today+': '+todayActs.map(a=>a.activity).join(', '))
    .replace('{stats}',stats)
    .replace('{language}',settings.promptLang||'English');
  return prompt;
}

async function callGroq(messages){
  const key=settings.groqApiKey;
  if(!key)throw new Error('No Groq API key. Add it in Settings → AI Configuration.');
  const res=await fetch('https://api.groq.com/openai/v1/chat/completions',{
    method:'POST',
    headers:{'Content-Type':'application/json','Authorization':'Bearer '+key},
    body:JSON.stringify({model:settings.groqModel||'llama-3.3-70b-versatile',messages,max_tokens:1500,temperature:0.7})
  });
  if(!res.ok){
    let errMsg='Groq API error '+res.status;
    try{const errData=await res.json();errMsg=errData?.error?.message||errMsg;}catch{}
    throw new Error(errMsg);
  }
  const data=await res.json();
  if(data.error)throw new Error(data.error.message||'Groq API error');
  return data.choices[0].message.content;
}

