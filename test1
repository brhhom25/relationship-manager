<script>
'use strict';
// =====================================================================
// SECURITY HELPERS — ALWAYS use these for user-supplied content
// =====================================================================
/**
 * esc() — HTML-encode a string so it is safe to embed in HTML text.
 * Use this ONLY when you truly need innerHTML; prefer textContent always.
 */
function esc(s){
  if(s==null)return'';
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#x27;')
    .replace(/\//g,'&#x2F;');
}

/** Sanitize a phone number — digits, +, spaces, dashes only */
function sanitizePhone(s){return String(s).replace(/[^0-9+\s\-]/g,'').slice(0,20);}

/** Validate a URL is http/https only */
function isSafeUrl(url){
  try{const u=new URL(url);return u.protocol==='https:'||u.protocol==='http:';}catch{return false;}
}

/** Safe external link opener */
function openExternalLink(url){if(isSafeUrl(url))window.open(url,'_blank','noopener,noreferrer');}

/** Strip any HTML/script tags from user input before storing */
function sanitizeText(s,maxLen=200){
  return String(s||'').replace(/<[^>]*>/g,'').replace(/[<>]/g,'').trim().slice(0,maxLen);
}

/** Safe textContent setter — never allows HTML injection */
function setText(id,val){const e=document.getElementById(id);if(e)e.textContent=String(val??'');}

// =====================================================================
// CONSTANTS
// =====================================================================
