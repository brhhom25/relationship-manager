function calcStats(){
  const wu=toMin(settings.wakeUpTime),sl=toMin(settings.sleepTime);const awake=Math.max(0,sl-wu);
  const acts=getDayActs();const total=acts.reduce((s,a)=>s+a.duration,0);const free=Math.max(0,awake-total);
  setText('statAwake',awake);setText('statSched',total);setText('statSchedPct',awake?Math.round(total/awake*100):0);setText('statFree',free);setText('statFreePct',awake?Math.round(free/awake*100):0);
}
function updatePie(){
  const wu=toMin(settings.wakeUpTime),sl=toMin(settings.sleepTime);const awake=Math.max(0,sl-wu);
  const awakePct=Math.round(awake/1440*100);setText('awakePct',awakePct+'%');
  const ap=document.getElementById('awakePie');if(ap)ap.style.background=`conic-gradient(var(--accent-color) 0% ${100-awakePct}%,var(--primary-color) ${100-awakePct}% 100%)`;
  const acts=getDayActs();const total=acts.reduce((s,a)=>s+a.duration,0);const actPct=awake?Math.round(total/awake*100):0;
