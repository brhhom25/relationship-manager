// =====================================================================
// FIREBASE — FIXED connections (dynamic import with proper error chain)
// =====================================================================
async function initFirebase(){
  const saveBtn=document.getElementById('fbPushBtn');const pullBtn=document.getElementById('fbPullBtn');
  const fc={
    apiKey:sanitizeText(document.getElementById('fbApiKey').value,200),
    projectId:sanitizeText(document.getElementById('fbProjectId').value,100),
    authDomain:sanitizeText(document.getElementById('fbAuthDomain').value,200),
    databaseURL:sanitizeText(document.getElementById('fbDatabaseURL').value,300),
    appId:sanitizeText(document.getElementById('fbAppId').value,200),
    syncPath:sanitizeText(document.getElementById('fbSyncPath').value,100)||'planners/default'
  };
  // Validate databaseURL
  if(!isSafeUrl(fc.databaseURL)||!fc.databaseURL.includes('firebaseio.com')){fbLog('❌ Invalid databaseURL — must be https://*.firebaseio.com');updateFBStatus('disconnected','Invalid databaseURL');return;}
  if(!fc.apiKey||!fc.projectId){fbLog('⚠️ apiKey and projectId are required');updateFBStatus('disconnected','Missing required fields');return;}
  settings.firebaseConfig=fc;savePlan();
  fbLog('Connecting to Firebase…');updateFBStatus('syncing','Connecting…');
  try{
    // Dynamically import Firebase modules
    const[appMod,dbMod]=await Promise.all([
      import('https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js'),
      import('https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js')
    ]);
    const{initializeApp,getApps,getApp,deleteApp}=appMod;
    const{getDatabase,ref,set,get}=dbMod;
    // Clean up previous app instance if exists
    const existing=getApps().find(a=>a.name==='daily-planner');
    if(existing)await deleteApp(existing);
    firebaseApp=initializeApp(fc,'daily-planner');
    const db=getDatabase(firebaseApp);
    // Test write
    await set(ref(db,fc.syncPath+'/meta'),{lastConnected:new Date().toISOString(),version:'4.0'});
    firebaseConnected=true;
    updateFBStatus('connected','Connected ✅');fbLog('✅ Firebase connected');
    if(saveBtn)saveBtn.disabled=false;if(pullBtn)pullBtn.disabled=false;
    notify('Firebase connected!','var(--success-color)');
  }catch(e){
    firebaseConnected=false;
    updateFBStatus('disconnected','Error: '+(e.message||'Unknown'));
    fbLog('❌ '+(e.message||'Connection failed'));
    if(saveBtn)saveBtn.disabled=true;if(pullBtn)pullBtn.disabled=true;
  }
}
async function firebasePush(){
  if(!firebaseConnected||!firebaseApp){notify('Connect Firebase first!','var(--error-color)');return;}
  fbLog('Pushing data…');updateFBStatus('syncing','Pushing…');
  try{
    const[,dbMod]=await Promise.all([import('https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js'),import('https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js')]);
    const{getDatabase,ref,set}=dbMod;
    const db=getDatabase(firebaseApp);const path=settings.firebaseConfig.syncPath;
    // Sanitize before push
    const cleanActs={};DAYS.forEach(d=>{cleanActs[d]=(activities[d]||[]).map(a=>({...a,activity:sanitizeText(a.activity,120),description:sanitizeText(a.description||'',500),goal:sanitizeText(a.goal||'',200),location:sanitizeText(a.location||'',200)}));});
    await Promise.all([set(ref(db,path+'/activities'),cleanActs),set(ref(db,path+'/tracking'),actTracking),set(ref(db,path+'/pushedAt'),new Date().toISOString())]);
    updateFBStatus('connected','Synced ✅');fbLog('✅ Pushed at '+new Date().toLocaleTimeString());notify('Synced to Firebase!','var(--success-color)');
  }catch(e){updateFBStatus('connected','Push failed');fbLog('❌ Push: '+(e.message||'error'));}
}
async function firebasePull(){
  if(!firebaseConnected||!firebaseApp){notify('Connect Firebase first!','var(--error-color)');return;}
  fbLog('Pulling data…');updateFBStatus('syncing','Pulling…');
  try{
    const[,dbMod]=await Promise.all([import('https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js'),import('https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js')]);
    const{getDatabase,ref,get}=dbMod;
    const db=getDatabase(firebaseApp);const path=settings.firebaseConfig.syncPath;
    const snap=await get(ref(db,path));const d=snap.val();
    if(d){
      if(d.activities&&typeof d.activities==='object'){
        // Sanitize pulled data
        DAYS.forEach(day=>{if(d.activities[day])activities[day]=d.activities[day].map(a=>({...a,activity:sanitizeText(a.activity,120),description:sanitizeText(a.description||'',500)}));});
      }
      if(d.tracking&&typeof d.tracking==='object')actTracking=d.tracking;
      DAYS.forEach(day=>sortDay(day));savePlan();renderAll();
      updateFBStatus('connected','Pulled ✅');fbLog('✅ Pulled at '+new Date().toLocaleTimeString());notify('Data pulled!','var(--secondary-color)');
    }else{fbLog('⚠️ No data in Firebase yet');}
  }catch(e){updateFBStatus('connected','Pull failed');fbLog('❌ Pull: '+(e.message||'error'));}
}
async function fbDisconnect(){
  if(firebaseApp){
    try{
      const{deleteApp}=await import('https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js');
      await deleteApp(firebaseApp);
    }catch(e){}
  }
  firebaseConnected=false;firebaseApp=null;
  updateFBStatus('disconnected','Disconnected');
  const sp=document.getElementById('fbPushBtn');const pp=document.getElementById('fbPullBtn');if(sp)sp.disabled=true;if(pp)pp.disabled=true;
  fbLog('Disconnected');notify('Firebase disconnected');
}
