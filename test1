function processAIActions(text){
  const actionRegex=/<action>([\s\S]*?)<\/action>/g;
  let match;let modified=text;
  while((match=actionRegex.exec(text))!==null){
    try{
      const action=JSON.parse(match[1]);
      // Sanitize action fields
      if(action.activity)action.activity=sanitizeText(action.activity,120);
      if(action.day&&!DAYS.includes(action.day))continue;
      if(action.type==='add'){
        const day=action.day||currentDay;
        if(!activities[day])activities[day]=[];
        activities[day].push({
          category:ACTS_DATA[action.category]?action.category:'Other',
          activity:action.activity||'New Activity',
          time:action.time||'09:00',
          duration:Math.max(1,Math.min(1440,parseInt(action.duration)||30)),
          color:CAT_COLORS[action.category]||'#FF6B6B',
          repeat:'none'
        });
        sortDay(day);renderAll();savePlan();notify('➕ AI added: '+action.activity,'var(--ai-color)');
      } else if(action.type==='delete'){
        const day=action.day||currentDay;
        const idx=(activities[day]||[]).findIndex(a=>a.activity===action.activity&&(!action.time||a.time===action.time));
        if(idx>-1){activities[day].splice(idx,1);renderAll();savePlan();notify('🗑️ AI deleted: '+action.activity,'var(--warning-color)');}
      } else if(action.type==='mark_done'){
        const day=action.day||currentDay;
        const idx=(activities[day]||[]).findIndex(a=>a.activity===action.activity&&(!action.time||a.time===action.time));
        if(idx>-1){toggleDone(day,idx);renderAll();notify('✅ AI marked done: '+action.activity,'var(--success-color)');}
      }
      modified=modified.replace(match[0],'');
    }catch(e){}
  }
  return modified.trim();
}

// DOM-safe AI message builder
function addAIMsg(role,text){
  const msgs=document.getElementById('aiMessages');if(!msgs)return;
  const div=document.createElement('div');div.className='ai-msg '+role;
  const av=document.createElement('div');av.className='ai-msg-av';av.textContent=role==='user'?'👤':'🤖';
  const content=document.createElement('div');
  const bubble=document.createElement('div');bubble.className='ai-bubble';
  // Safe rendering: split on newlines and bold markers, build DOM nodes
  const lines=text.split('\n');
  lines.forEach((line,i)=>{
    // Handle **bold** markers safely
    const parts=line.split(/\*\*(.*?)\*\*/g);
    parts.forEach((part,j)=>{
      if(j%2===1){const b=document.createElement('strong');b.textContent=part;bubble.appendChild(b);}
      else if(part){bubble.appendChild(document.createTextNode(part));}
    });
    if(i<lines.length-1)bubble.appendChild(document.createElement('br'));
  });
  const time=document.createElement('span');time.className='ai-msg-time';
  time.textContent=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  content.appendChild(bubble);content.appendChild(time);
  div.appendChild(av);div.appendChild(content);msgs.appendChild(div);
  msgs.scrollTop=msgs.scrollHeight;
}

