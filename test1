function renderGridView(){
  const grid=document.getElementById('calGrid');grid.innerHTML='';grid.className='calendar-grid';
  const wu=toMin(settings.wakeUpTime),sl=toMin(settings.sleepTime);
  const iv=parseInt(document.getElementById('timeInterval').value)||30;
  const acts=getDayActs();
  for(let i=0;i<Math.ceil((sl-wu)/iv);i++){
    const ss=wu+i*iv,se=Math.min(ss+iv,sl);
    const hour=document.createElement('div');hour.className='calendar-hour';
    const t1=document.createElement('div');t1.textContent=toTime(ss);
    const t2=document.createElement('div');t2.style.cssText='font-size:.82rem;color:var(--secondary-color);';t2.textContent=`${se-ss}m`;
    hour.appendChild(t1);hour.appendChild(t2);grid.appendChild(hour);
    const slot=document.createElement('div');slot.className='calendar-slot';
    makeDropZone(slot,currentDay,toTime(ss));
    slot.addEventListener('click',()=>{if(dragState.active)return;const qd=document.getElementById('quickDate');if(qd)qd.value=getViewDateISO();const qt=document.getElementById('quickTime');if(qt)qt.value=toTime(ss);openMainTab('activities');openActSub('quick');});
    const here=acts.filter(a=>{const as=toMin(a.time);return ss>=as&&ss<as+a.duration;});
    if(!here.length)slot.classList.add('empty');
    here.forEach(act=>{
      const ri=(activities[currentDay]||[]).indexOf(act);
      const ae=toMin(act.time)+act.duration;
      const key=`${currentDay}_${act.activity}_${act.time}`;
