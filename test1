// =====================================================================
// ZOOM
// =====================================================================
function applyZoom(gid){
  const ids=gid?[gid]:['calGrid','weeklyGrid','monthlyGrid'];
  ids.forEach(id=>{const el=document.getElementById(id);if(el)el.style.transform=`scale(${zoomLevel})`;});
  ['zoomInd','weekZoomInd','monthZoomInd'].forEach(id=>{setText(id,Math.round(zoomLevel*100)+'%');});
}
function zoomIn(){zoomLevel=Math.min(3,+(zoomLevel+0.1).toFixed(1));applyZoom();}
function zoomOut(){zoomLevel=Math.max(0.5,+(zoomLevel-0.1).toFixed(1));applyZoom();}
function resetZoom(){zoomLevel=1;applyZoom();}

