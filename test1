function importData(input){
  const file=input.files[0];if(!file)return;
  if(!file.name.endsWith('.json')){notify('Only JSON files allowed!','var(--error-color)');return;}
  if(file.size>5*1024*1024){notify('File too large (max 5MB)','var(--error-color)');return;}
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      // Validate JSON structure before applying
      const d=JSON.parse(e.target.result);
      if(typeof d!=='object'||Array.isArray(d))throw new Error('Invalid structure');
      if(d.activities&&typeof d.activities==='object')activities=d.activities;
      if(d.actTracking&&typeof d.actTracking==='object')actTracking=d.actTracking;
      if(d.settings&&typeof d.settings==='object')settings={...settings,...d.settings};
      if(d.wakeSleepHistory&&typeof d.wakeSleepHistory==='object')wakeSleepHistory=d.wakeSleepHistory;
      if(d.gamification&&typeof d.gamification==='object')gamification={...gamification,...d.gamification};
      // Sanitize all activity names after import
      DAYS.forEach(day=>{(activities[day]||[]).forEach(act=>{act.activity=sanitizeText(act.activity,120);act.description=sanitizeText(act.description||'',500);act.goal=sanitizeText(act.goal||'',200);act.location=sanitizeText(act.location||'',200);});sortDay(day);});
      savePlan();loadSettingsUI();renderAll();
      ['importStatus','importStatusSettings'].forEach(id=>{const el=document.getElementById(id);if(el){el.textContent='✅ Import successful!';el.className='import-status success';}});
      notify('Data imported!');
    }catch(err){
      ['importStatus','importStatusSettings'].forEach(id=>{const el=document.getElementById(id);if(el){el.textContent='❌ Import failed: '+err.message;el.className='import-status error';}});
    }
  };
  reader.readAsText(file);
  input.value=''; // reset file input
}

