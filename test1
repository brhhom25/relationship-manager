function updateDayNav(){
  const d=getViewDateObj();
  const todayStr=new Date().toDateString();
  const tmr=new Date();tmr.setDate(tmr.getDate()+1);
  const yest=new Date();yest.setDate(yest.getDate()-1);
  let suf='';
  if(d.toDateString()===todayStr)suf=' (Today)';
  else if(d.toDateString()===tmr.toDateString())suf=' (Tomorrow)';
  else if(d.toDateString()===yest.toDateString())suf=' (Yesterday)';
  setText('dayNavLabel',`${currentDay}, ${d.toLocaleDateString('en-US',{month:'short',day:'numeric'})}${suf}`);
  setText('calDayDisplay',`${currentDay} — ${getViewDateISO()}`);
}
function prevDay(){currentDayOffset--;currentDay=DOW[getViewDateObj().getDay()];syncDayUI();}
function nextDay(){currentDayOffset++;currentDay=DOW[getViewDateObj().getDay()];syncDayUI();}
function jumpToToday(){currentDayOffset=0;currentDay=new Date().toLocaleDateString('en-US',{weekday:'long'});syncDayUI();}
function syncDayUI(){
  const ds=document.getElementById('daySelect');if(ds)ds.value=currentDay;
  const qd=document.getElementById('quickDate');if(qd)qd.value=getViewDateISO();
  updateDayNav();renderCalendarView();calcStats();updatePie();
}
function getWeekDays(){
  const today=new Date();const diff=today.getDay()===0?-6:1-today.getDay();
  const start=new Date(today);start.setDate(today.getDate()+diff+(weekOffset*7));
  return Array.from({length:7},(_,i)=>{const d=new Date(start);d.setDate(start.getDate()+i);return{name:DOW[d.getDay()],date:d};});
}
function updateWeekNav(){
  const days=getWeekDays();const fmt=d=>d.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  setText('weekNavLabel',`${fmt(days[0].date)} – ${fmt(days[6].date)}${weekOffset===0?' (This Week)':''}`);
}
function prevWeek(){weekOffset--;updateWeekNav();renderWeeklyView();}
function nextWeek(){weekOffset++;updateWeekNav();renderWeeklyView();}
function jumpToThisWeek(){weekOffset=0;updateWeekNav();renderWeeklyView();}
function setDailyView(v){currentDailyView=v;settings.dailyViewType=v;renderCalendarView();savePlan();}
function handleDaySelectChange(){
  const day=document.getElementById('daySelect').value;currentDay=day;
  const today=new Date();today.setHours(0,0,0,0);
  const tIdx=DAYS.indexOf(day);const todIdx=DAYS.indexOf(today.toLocaleDateString('en-US',{weekday:'long'}));
  let diff=tIdx-todIdx;if(diff<0)diff+=7;currentDayOffset=diff;
  const qd=document.getElementById('quickDate');if(qd)qd.value=getViewDateISO();
  renderCalendarView();calcStats();updatePie();renderCheckTab();
}

