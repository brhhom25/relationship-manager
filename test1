  const name=settings.promptUserName||'there';
  if(type==='morning'){return `🌅 Good morning ${name}!\n\nToday you have ${acts.length} activities planned.${firstAct?'\n⏰ First up: '+firstAct.activity+' at '+firstAct.time:''}\n\n📊 Overall completion rate: ${rate}%\n\n💪 Let's make today amazing!`;}
  if(type==='evening'){const dayDone=(activities[currentDay]||[]).filter(a=>(actTracking[`${currentDay}_${a.activity}_${a.time}`]||{}).completed);return `🌙 Evening Summary — ${new Date().toLocaleDateString()}\n\n✅ Completed: ${dayDone.length}/${acts.length}\n${dayDone.slice(0,5).map(a=>'• '+a.activity).join('\n')}\n\n🌟 Well done, ${name}!`;}
  if(type==='tips'){return `💡 Daily Tips for ${name}:\n\n1. Stay consistent with your schedule\n2. Take breaks between activities\n3. Review your goals regularly\n4. Celebrate small wins\n5. Stay hydrated!\n\n🎯 Completion rate: ${rate}%`;}
  if(type==='motivation'){return `💪 You've got this, ${name}!\n\n🔥 Streak: ${gamification.streak} days\n⭐ Level: ${gamification.level}\n✅ Total done: ${gamification.totalCompleted}\n\n"Success is the sum of small efforts repeated daily."\n\nKeep going! 🚀`;}
  // Custom template
  const tmpl=settings.waTemplate||`🌟 Hello {name}! Today you have {count} activities.${firstAct?' First: {first_activity} at {first_time}.':''} Rate: {completion_rate}`;
  return tmpl.replace('{name}',name).replace('{count}',acts.length).replace('{first_activity}',firstAct?.activity||'').replace('{first_time}',firstAct?.time||'').replace('{date}',new Date().toLocaleDateString()).replace('{completion_rate}',rate+'%');
}
